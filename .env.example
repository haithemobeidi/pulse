# Pulse (PC-Inspector) Configuration

# Database
DATABASE_PATH=data/system.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
DEBUG=False

# AI Providers (at least one needed for AI diagnosis)
# Priority: Ollama (local/free) → Gemini (your subscription) → Claude (pay-per-use)

# Google Gemini - Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude (optional backup) - Get from https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-api-key-here

# Ollama runs locally, no key needed - just install from https://ollama.com

# Data Collection
COLLECTION_INTERVAL_HOURS=4
REALTIME_INTERVAL_SECONDS=300
